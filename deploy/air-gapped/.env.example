# Copy to .env in this directory for
# `docker compose -f docker-compose.airgapped.yml up`.
#
# Only SIDECAR_AUTH_TOKEN is required for the round trip this directory's
# README.md documents (MinIO stays on its in-compose defaults). See the
# repo root's .env.example for the full set of variables the sidecar
# understands (S3/Azure backend selection, etc.) — this file intentionally
# doesn't duplicate all of it.

SIDECAR_AUTH_TOKEN=                                # CHANGEME - openssl rand -hex 32
