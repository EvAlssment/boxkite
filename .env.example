# boxkite configuration — copy to .env for `docker compose -f deploy/docker-compose.yml up`
#
# Fields marked CHANGEME are the ones you actually need to fill in for a
# non-local deployment. Everything else works out of the box.

# ============================================
# Sidecar HTTP API authentication (REQUIRED)
# ============================================
# The sidecar's HTTP API (:8080 — /exec, /file-create, /view, etc.) has no
# authentication of its own beyond this shared secret. Network isolation
# (the docker-compose internal network, or a K8s NetworkPolicy in
# production) is a second, independent layer, not a substitute for this —
# NetworkPolicy enforcement is CNI-dependent and not guaranteed on every
# setup. `docker compose up` will refuse to start the sidecar if this is
# left empty (fail closed, not silently open).
#
# Generate one with: openssl rand -hex 32
#
# Whatever process embeds `boxkite.SandboxManager` needs this SAME value in
# its own environment (also as SIDECAR_AUTH_TOKEN) so it can send it back on
# every sidecar request — see the README quickstart.
SIDECAR_AUTH_TOKEN=                                # CHANGEME - openssl rand -hex 32

# ============================================
# Storage backend selection: "s3" or "azure"
# ============================================
STORAGE_BACKEND=s3

# ============================================
# S3 / MinIO configuration
# ============================================
# Defaults below point at the MinIO container docker-compose already starts
# for you — safe to leave as-is for local dev ON YOUR OWN MACHINE. MinIO's
# ports are bound to 127.0.0.1 only (not just "the compose network" — a
# previous version of this comment overstated that), so the well-known
# admin/admin default is fine as long as you're running compose locally.
# If you deploy this compose file to any shared/cloud host, change
# MINIO_ROOT_USER/MINIO_ROOT_PASSWORD to real credentials first and don't
# widen the 127.0.0.1 bind in deploy/docker-compose.yml.
S3_ENDPOINT=http://minio:9000
S3_BUCKET=boxkite-sandbox
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# For real AWS S3 in production (leave S3_ENDPOINT empty for AWS S3 itself):
# S3_ENDPOINT=
# S3_BUCKET=your-bucket-name                      # CHANGEME
# AWS_REGION=us-east-1                             # CHANGEME
# AWS_ACCESS_KEY_ID=your-access-key                # CHANGEME - from AWS IAM, or use IRSA in EKS instead
# AWS_SECRET_ACCESS_KEY=your-secret-key            # CHANGEME - from AWS IAM, or use IRSA in EKS instead

# ============================================
# Azure Blob Storage configuration
# ============================================
# Only needed if STORAGE_BACKEND=azure. Leave empty for the S3/MinIO default.
AZURE_STORAGE_CONNECTION_STRING=                   # CHANGEME if using Azure - from the Storage Account "Access keys" blade
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_STORAGE_CONTAINER=boxkite-storage

# ============================================
# Kubernetes mode only (deploy/local-kind/ or a real cluster)
# ============================================
# Not used by docker-compose — see deploy/local-kind/README.md and the
# top-level README's Kubernetes quickstart for the full list.
# RUNTIME_MODE=k8s
# SANDBOX_IMAGE=boxkite-sandbox:latest
# SIDECAR_IMAGE=boxkite-sidecar:latest
# SANDBOX_NAMESPACE=default
# WARM_POOL_SIZE=3
# WARM_POOL_MAX=15
#
# When running against an external (non-in-cluster) kubeconfig -- e.g. a
# control-plane deployed on a managed serverless platform outside the
# cluster -- the manager self-mints a short-lived replacement ServiceAccount
# token via TokenRequest instead of relying indefinitely on the kubeconfig's
# original static token. See src/boxkite/k8s_auth.py. Enabled by default;
# only disable for local debugging where a real ServiceAccount/RBAC binding
# isn't set up.
# The default below already matches deploy/rbac.yaml's ServiceAccount name
# -- only set this if you renamed that ServiceAccount in your own manifests
# (a mismatch fails silently: each mint attempt 403s, is logged, and the app
# keeps running on the original static bootstrap token indefinitely).
# CONTROL_PLANE_SERVICE_ACCOUNT_NAME=boxkite-control-plane
# CONTROL_PLANE_TOKEN_ROTATION_ENABLED=true
# CONTROL_PLANE_TOKEN_ROTATION_EXPIRATION_SECONDS=3600
