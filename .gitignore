# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.venv/
.venv-local/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
build/
dist/

# Env files (never commit real secrets)
.env
.env.local
*.env.bak

# Generated by .claude/skills/worktree/bootstrap.sh -- per-worktree port
# assignment and dev-server launcher, regenerated on every bootstrap run.
.env.worktree
/run-worktree.sh

# Editor / OS
.DS_Store
.idea/
.vscode/

# Docker Compose volumes note: MinIO/session data lives in named Docker
# volumes, not bind-mounted into the repo, so nothing to ignore here.

# control-plane local SQLite dev DB (see control-plane/.env.example) —
# never a real Postgres deployment artifact, just a zero-config local default.
control-plane/*.db
*.db-journal

# Air-gapped bundle output (deploy/air-gapped/mirror-images.sh) — a
# multi-hundred-MB docker save tarball + manifest, regenerated locally by
# whoever runs the mirror step, never a repo artifact.
deploy/air-gapped/bundle/

# Node (deploy/ skill deps)
node_modules/

# Rust (sdk-rust/) build output -- Cargo.lock IS committed (reproducible CI),
# only the compiled target/ directory is ignored.
target/

# Claude Code session/agent state (worktrees, skills, scheduled tasks,
# mailbox, etc.) — local to each checkout, never committed.
.claude/
