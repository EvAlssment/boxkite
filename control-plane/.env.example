# boxkite control-plane configuration — copy to control-plane/.env for local dev.
#
# This service is independent of the root .env used by
# deploy/docker-compose.yml, but it embeds boxkite.SandboxManager directly,
# so it also needs whichever RUNTIME_MODE/SIDECAR_AUTH_TOKEN/storage
# variables that package reads from the environment — see the root
# .env.example for the full list. Nothing below duplicates those; this file
# is only the control-plane-specific configuration.

# ============================================
# Persistence (REQUIRED for anything beyond local dev)
# ============================================
# Defaults to a local SQLite file if unset — convenient for a first run, not
# suitable for a real multi-instance deployment. Point this at this org's
# standard shared Postgres in any real deployment:
DATABASE_URL=sqlite+aiosqlite:///./control_plane.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/boxkite_control_plane   # CHANGEME for production

# ============================================
# Environment
# ============================================
# Defaults to "development". Set to anything else (e.g. "production") in a
# real deployment — this is what makes the JWT_SECRET check below fail
# startup instead of just warning.
ENVIRONMENT=development

# ============================================
# API docs
# ============================================
# Swagger UI (/docs), ReDoc (/redoc), and /openapi.json. Unset by default:
# enabled automatically when ENVIRONMENT is development/dev/test/testing,
# disabled otherwise. Set explicitly (true/false) to override either way.
# ENABLE_API_DOCS=false

# ============================================
# Auth (REQUIRED for anything beyond local dev)
# ============================================
# Signs the short-lived dashboard JWT. The app logs a warning at startup if
# this is left at its insecure placeholder value while ENVIRONMENT is
# development/dev/test/testing, and refuses to start otherwise.
#
# Generate one with: openssl rand -hex 32
JWT_SECRET=                                        # CHANGEME - openssl rand -hex 32
ACCESS_TOKEN_TTL_MINUTES=30

# ============================================
# Fair-use limits (NOT pricing tiers — no billing concept exists here)
# ============================================
BOXKITE_FREE_MONTHLY_SANDBOX_HOURS=20
BOXKITE_MAX_SESSION_MINUTES=30
BOXKITE_MAX_CONCURRENT_SANDBOXES=2
# Cluster-wide ceiling across ALL accounts -- see config.py for sizing notes.
BOXKITE_GLOBAL_MAX_CONCURRENT_SANDBOXES=20
BOXKITE_SESSION_REAPER_INTERVAL_SECONDS=60

# ============================================
# Abuse resistance
# ============================================
BOXKITE_AUTH_RATE_LIMIT_PER_MINUTE=10
BOXKITE_SANDBOX_LIFECYCLE_RATE_LIMIT_PER_MINUTE=20

# ============================================
# Networking
# ============================================
CONTROL_PLANE_PORT=8090

# ============================================
# CORS (comma-separated browser-client origins -- empty by default; see
# config.py for why this is a response-confidentiality control, not CSRF)
# ============================================
CORS_ALLOWED_ORIGINS_RAW=

# ============================================
# Social login (GitHub/Google) -- off by default, see
# docs/MCP-OAUTH-AND-SOCIAL-LOGIN-DESIGN.md and GitHub issue #114.
# Each provider independently fails safe (stays unexposed) unless BOTH of
# its own two env vars are set -- see config.py's github_oauth_configured()/
# google_oauth_configured().
# ============================================
BOXKITE_SOCIAL_LOGIN_ENABLED=false
# GitHub OAuth App: github.com/settings/developers -> "New OAuth App".
# Authorization callback URL must be: <this deployment's base URL>/v1/auth/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# Google OAuth 2.0 Client: console.cloud.google.com/apis/credentials.
# Authorized redirect URI must be: <this deployment's base URL>/v1/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ============================================
# MCP OAuth 2.1 authorization server (inbound, for MCP clients connecting to
# this deployment's hosted /mcp endpoint) -- off by default, see
# docs/MCP-OAUTH-AND-SOCIAL-LOGIN-DESIGN.md and GitHub issue #114. Supports
# RFC 7591 dynamic client registration (POST /oauth/register) -- no external
# app registration needed, unlike social login above.
# ============================================
BOXKITE_MCP_OAUTH_ENABLED=false
