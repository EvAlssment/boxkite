{
  "name": "boxkite-client",
  "version": "0.1.0",
  "description": "TypeScript/JavaScript client for a hosted boxkite control-plane (sandbox creation, exec, files).",
  "license": "FSL-1.1-Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/HarshitKmr10/boxkite.git",
    "directory": "sdk-js"
  },
  "homepage": "https://github.com/HarshitKmr10/boxkite/tree/main/sdk-js#readme",
  "bugs": "https://github.com/HarshitKmr10/boxkite/issues",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": "./dist/src/index.js",
